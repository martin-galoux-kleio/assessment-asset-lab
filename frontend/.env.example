# Copy to .env and set your token (must match backend ADMIN_TOKEN).
# Only VITE_* variables are exposed to the client.
VITE_ADMIN_TOKEN=your-admin-token

# Production: set to your backend URL so the deployed frontend calls the right API.
# Leave unset in dev (Vite proxy forwards /api to localhost:3000).
# VITE_API_BASE_URL=https://assessment-asset-lab-production.up.railway.app
